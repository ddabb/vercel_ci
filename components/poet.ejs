<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Language" content="zh-CN">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9093386396178901"
        crossorigin="anonymous"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= poet.Name %>诗词集 - <%= poet.Dynasty || '' %>诗人<%= poet.Name ? '的诗歌作品' : '' %></title>
    <meta name="description" content="<%= poet.Dynasty ? poet.Dynasty + '诗人' : '' %><%= poet.Name %>的诗词作品集<%= poet.Description ? '，' + poet.Name + (poet.Birth || poet.Death ? '（' + (poet.Birth || '?') + '-' + (poet.Death || '?') + '）' : '') + '，' + poet.Description.substring(0, 80) : '' %>。收录<%= poet.Poems ? poet.Poems.length : 0 %>首诗。">
    <meta name="keywords" content="<%= poet.Name %>,<%= poet.Name %>诗词,<%= poet.Name %>诗,<%= poet.Dynasty || '' %>诗人,<%= poet.Name %>诗集,<%= poet.Name %>作品,<%= poet.Name %>名句">
    <link rel="icon" href="../logo.svg" type="image/svg+xml">
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/footer.css">
    <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"
         crossorigin="anonymous"></script>
    <script src="../js/clarity.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/masonry/4.2.2/masonry.pkgd.min.js"></script>

    <!-- Open Graph -->
    <meta property="og:title" content="<%= poet.Name %>诗词集 - <%= poet.Dynasty || '' %>诗人">
    <meta property="og:description" content="<%= poet.Dynasty ? poet.Dynasty + '诗人' : '' %><%= poet.Name %>的诗词作品集，共<%= poet.Poems ? poet.Poems.length : 0 %>首。">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="zh_CN">
    <meta property="og:site_name" content="60score自助工具站">

    <!-- JSON-LD Structured Data: Person + CollectionPage -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@graph": [
            {
                "@type": "Person",
                "name": "<%= poet.Name %>",
                <% if(poet.Dynasty) { %>"jobTitle": "<%= poet.Dynasty %>诗人",<% } %>
                <% if(poet.Birth) { %>"birthDate": "<%= poet.Birth %>",<% } %>
                <% if(poet.Death) { %>"deathDate": "<%= poet.Death %>",<% } %>
                <% if(poet.Description) { %>"description": "<%= poet.Description.replace(/"/g, '&quot;').substring(0, 200) %>",<% } %>
                "mainEntityOfPage": {
                    "@type": "CollectionPage",
                    "name": "<%= poet.Name %>诗词集",
                    "description": "<%= poet.Name %>的全部诗词作品",
                    <% if(poet.Poems) { %>"numberOfItems": <%= poet.Poems.length %>,<% } %>
                    "url": "/sghtml/<%= poet.Name %>.html"
                }
            }
        ]
    }
    </script>

    <script>
        var _hmt = _hmt || [];
        (function () {
            var hm = document.createElement("script");
            hm.src = "https://hm.baidu.com/hm.js?9375ffd48c244c211aeaa2bd8c047a43";
            var s = document.getElementsByTagName("script")[0];
            s.parentNode.insertBefore(hm, s);
        })();
    </script>

    <style>
        /* Poet page enhanced styles */
        .poet-hero-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            overflow: hidden;
            margin-top: 80px;
            margin-bottom: 24px;
        }
        .poet-hero-card .card-body {
            padding: 28px 32px;
        }
        .poet-hero-card h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: 2px;
        }
        .poet-hero-card .poet-dynasty {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            padding: 3px 14px;
            border-radius: 20px;
            font-size: 0.9rem;
            margin-bottom: 12px;
        }
        .poet-hero-card .poet-years {
            font-size: 0.95rem;
            opacity: 0.9;
        }
        .poet-hero-card .poet-desc {
            font-size: 0.95rem;
            line-height: 1.8;
            margin-top: 12px;
            opacity: 0.95;
        }
        .poet-stats {
            display: flex;
            gap: 20px;
            margin-top: 16px;
            flex-wrap: wrap;
        }
        .poet-stats .stat-item {
            background: rgba(255,255,255,0.15);
            padding: 6px 16px;
            border-radius: 8px;
            font-size: 0.85rem;
        }
        .breadcrumb-poet {
            margin-top: 72px;
            margin-bottom: 8px;
            font-size: 0.85rem;
        }
        .breadcrumb-poet a {
            color: #667eea;
            text-decoration: none;
        }
        .breadcrumb-poet a:hover {
            text-decoration: underline;
        }
        .breadcrumb-poet .separator {
            margin: 0 6px;
            color: #999;
        }
        .section-title {
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #667eea;
            display: inline-block;
        }
        .poem-card {
            border: 1px solid #e8e8e8;
            border-radius: 10px;
            transition: box-shadow 0.2s ease, transform 0.2s ease;
            overflow: hidden;
        }
        .poem-card:hover {
            box-shadow: 0 4px 16px rgba(102,126,234,0.15);
            transform: translateY(-2px);
        }
        .poem-card .card-body {
            padding: 16px 20px;
        }
        .poem-card .card-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
        }
        .poem-card .poem-form-badge {
            display: inline-block;
            background: #f0f4ff;
            color: #667eea;
            font-size: 0.75rem;
            padding: 2px 10px;
            border-radius: 12px;
            margin-bottom: 10px;
        }
        .poem-card .poem-tags {
            font-size: 0.75rem;
            color: #999;
            margin-bottom: 10px;
        }
        .poem-card pre {
            font-family: "Noto Serif SC", "SimSun", "STSong", serif;
            font-size: 0.95rem;
            line-height: 2;
            color: #333;
            background: #fafafa;
            border: none;
            padding: 12px 16px;
            border-radius: 8px;
            white-space: pre-wrap;
            word-wrap: break-word;
            margin: 0;
        }
        .poem-card .famous-lines {
            background: #fffbe6;
            border-left: 3px solid #ffc53d;
            padding: 8px 14px;
            margin-top: 10px;
            border-radius: 0 6px 6px 0;
            font-size: 0.85rem;
            color: #8c6d1f;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #999;
        }
        @media (max-width: 768px) {
            .poet-hero-card .card-body {
                padding: 20px 18px;
            }
            .poet-hero-card h1 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>

<body>
    <%- include('../components/header.ejs') %>

    <div class="container-fluid" style="max-width:1200px; margin:0 auto; padding:0 16px;">
        <!-- Breadcrumb Navigation -->
        <nav class="breadcrumb-poet">
            <a href="../html/index.html">首页</a>
            <span class="separator">/</span>
            <a href="dynasties.html">朝代诗人</a>
            <span class="separator">/</span>
            <span><%= poet.Name %></span>
        </nav>

        <!-- Poet Hero Card -->
        <div class="card poet-hero-card">
            <div class="card-body">
                <h1><%= poet.Name %></h1>
                <% if(poet.Dynasty) { %>
                    <span class="poet-dynasty"><%= poet.Dynasty %></span>
                <% } %>
                <% if(poet.Birth || poet.Death) { %>
                    <div class="poet-years">
                        <i class="bi bi-clock-history"></i>
                        <%= poet.Birth || '?' %> — <%= poet.Death || '?' %>
                    </div>
                <% } %>
                <% if(poet.Description) { %>
                    <p class="poet-desc"><%= poet.Description %></p>
                <% } %>
                <div class="poet-stats">
                    <span class="stat-item">
                        <i class="bi bi-book"></i> 收录诗词 <%= poet.Poems ? poet.Poems.length : 0 %> 首
                    </span>
                    <% if(poet.Dynasty) { %>
                        <span class="stat-item">
                            <i class="bi bi-calendar-event"></i> <%= poet.Dynasty %>
                        </span>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Poems Section -->
        <h2 class="section-title"><%= poet.Name %>的诗词</h2>
        <% if (poet.Poems && poet.Poems.length > 0) { %>
            <div class="masonry-grid">
                <% poet.Poems.forEach(poem => { %>
                    <div class="masonry-grid-item">
                        <div class="card poem-card h-100">
                            <div class="card-body">
                                <h5 class="card-title"><%= poem.Name %></h5>
                                <% if(poem.Form && poem.Form !== '未知') { %>
                                    <span class="poem-form-badge"><%= poem.Form %></span>
                                <% } %>
                                <% if(poem.Tags && poem.Tags.length > 0) { %>
                                    <div class="poem-tags">
                                        <i class="bi bi-tag"></i> <%= poem.Tags.join(' · ') %>
                                    </div>
                                <% } %>
                                <pre><%= poem.Contents.join('\n') %></pre>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <i class="bi bi-journal-x" style="font-size:3rem;"></i>
                <p class="mt-3">暂未收录该诗人的诗词作品。</p>
            </div>
        <% } %>
    </div>

    <%- include('../components/footer.ejs') %>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var elem = document.querySelector('.masonry-grid');
            if (elem) {
                var msnry = new Masonry(elem, {
                    itemSelector: '.masonry-grid-item',
                    columnWidth: '.masonry-grid-item',
                    percentPosition: true,
                    gutter: 12
                });
            }
        });
    </script>
</body>

</html>
